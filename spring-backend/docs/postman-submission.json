{
  "info": {
    "name": "Xebia Portal Submission APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8082" },
    { "key": "teacherToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "batchId", "value": "" },
    { "key": "studentId", "value": "" },
    { "key": "assessmentId", "value": "" },
    { "key": "submissionId", "value": "" }
  ],
  "item": [
    {
      "name": "Login teacher",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"TEACHER\"\n}"
        }
      }
    },
    {
      "name": "Login student",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\"\n}"
        }
      }
    },
    {
      "name": "Create batch",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/batches",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Submission API Batch\",\n  \"course\": \"Backend Development\",\n  \"icon\": \"BookOpen\",\n  \"status\": \"ACTIVE\",\n  \"studentIds\": []\n}"
        }
      }
    },
    {
      "name": "List students",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
        "url": "{{baseUrl}}/api/v1/users?role=STUDENT"
      }
    },
    {
      "name": "Enroll student",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/batches/{{batchId}}/students",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentIds\": [\"{{studentId}}\"]\n}"
        }
      }
    },
    {
      "name": "Create published quiz assessment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/assessments",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Submission Flow Quiz\",\n  \"topic\": \"Java Basics\",\n  \"course\": \"Backend Development\",\n  \"subject\": \"Java\",\n  \"type\": \"QUIZ\",\n  \"difficulty\": \"EASY\",\n  \"status\": \"PUBLISHED\",\n  \"duration\": 30,\n  \"marks\": 15,\n  \"passingMarks\": 8,\n  \"maxAttempts\": 1,\n  \"negativeMarking\": false,\n  \"negativeMarksValue\": 0,\n  \"shuffleQuestions\": false,\n  \"autoSubmit\": true,\n  \"batchIds\": [\"{{batchId}}\"],\n  \"questions\": [\n    {\n      \"type\": \"MCQ\",\n      \"questionText\": \"Which keyword creates a subclass in Java?\",\n      \"marks\": 5,\n      \"required\": true,\n      \"options\": [\n        { \"optionText\": \"extends\", \"correct\": true },\n        { \"optionText\": \"implements\", \"correct\": false }\n      ]\n    },\n    {\n      \"type\": \"TRUE_FALSE\",\n      \"questionText\": \"Java supports interfaces.\",\n      \"marks\": 5,\n      \"required\": true,\n      \"options\": [\n        { \"optionText\": \"true\", \"correct\": true },\n        { \"optionText\": \"false\", \"correct\": false }\n      ]\n    },\n    {\n      \"type\": \"MULTIPLE_SELECT\",\n      \"questionText\": \"Select valid Java access modifiers.\",\n      \"marks\": 5,\n      \"required\": true,\n      \"options\": [\n        { \"optionText\": \"public\", \"correct\": true },\n        { \"optionText\": \"private\", \"correct\": true },\n        { \"optionText\": \"internal\", \"correct\": false }\n      ]\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Get assigned assessments as student",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
        "url": "{{baseUrl}}/api/v1/students/me/assessments"
      }
    },
    {
      "name": "Start submission",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{studentToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/submissions/start",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assessmentId\": \"{{assessmentId}}\"\n}"
        }
      }
    },
    {
      "name": "Submit answers",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{studentToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/submissions/{{submissionId}}/submit",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"timeTaken\": 420,\n  \"answers\": [\n    {\n      \"questionId\": \"PASTE_MCQ_QUESTION_ID_FROM_ASSESSMENT_RESPONSE\",\n      \"answerText\": \"extends\"\n    },\n    {\n      \"questionId\": \"PASTE_TRUE_FALSE_QUESTION_ID_FROM_ASSESSMENT_RESPONSE\",\n      \"answerText\": \"true\"\n    },\n    {\n      \"questionId\": \"PASTE_MULTIPLE_SELECT_QUESTION_ID_FROM_ASSESSMENT_RESPONSE\",\n      \"answerJson\": \"[\\\"public\\\", \\\"private\\\"]\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Get result",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
        "url": "{{baseUrl}}/api/v1/submissions/{{submissionId}}/result"
      }
    },
    {
      "name": "List submissions as teacher",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
        "url": "{{baseUrl}}/api/v1/submissions"
      }
    }
  ]
}
