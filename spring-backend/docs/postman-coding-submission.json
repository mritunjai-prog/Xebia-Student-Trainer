{
  "info": {
    "name": "Xebia Portal Coding Submission APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8082" },
    { "key": "teacherToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "batchId", "value": "" },
    { "key": "studentId", "value": "" },
    { "key": "assessmentId", "value": "" },
    { "key": "questionId", "value": "" },
    { "key": "codingSubmissionId", "value": "" }
  ],
  "item": [
    {
      "name": "Login teacher",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"TEACHER\"\n}"
        }
      }
    },
    {
      "name": "Login student",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\"\n}"
        }
      }
    },
    {
      "name": "Create batch",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/batches",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Coding API Batch\",\n  \"course\": \"Backend Development\",\n  \"icon\": \"Code\",\n  \"status\": \"ACTIVE\",\n  \"studentIds\": []\n}"
        }
      }
    },
    {
      "name": "Enroll student",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/batches/{{batchId}}/students",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentIds\": [\"{{studentId}}\"]\n}"
        }
      }
    },
    {
      "name": "Create coding assessment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/assessments",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Coding Sum Assessment\",\n  \"topic\": \"Functions\",\n  \"course\": \"Backend Development\",\n  \"subject\": \"Java\",\n  \"type\": \"CODING\",\n  \"difficulty\": \"EASY\",\n  \"status\": \"DRAFT\",\n  \"duration\": 45,\n  \"marks\": 20,\n  \"passingMarks\": 10,\n  \"maxAttempts\": 1,\n  \"negativeMarking\": false,\n  \"negativeMarksValue\": 0,\n  \"shuffleQuestions\": false,\n  \"autoSubmit\": true,\n  \"batchIds\": [\"{{batchId}}\"],\n  \"questions\": [\n    {\n      \"type\": \"CODING\",\n      \"questionText\": \"Return the sum of two integers.\",\n      \"marks\": 20,\n      \"required\": true,\n      \"sortOrder\": 0,\n      \"codingDetails\": {\n        \"difficulty\": \"EASY\",\n        \"timeLimitMs\": 1000,\n        \"memoryLimitMb\": 128,\n        \"constraintsText\": \"Inputs are integers between -1000 and 1000.\",\n        \"inputFormat\": \"Two integers a and b.\",\n        \"outputFormat\": \"Single integer sum.\",\n        \"sampleInput\": \"2 3\",\n        \"sampleOutput\": \"5\",\n        \"languagesAllowedJson\": \"[\\\"java\\\"]\",\n        \"templates\": [\n          { \"language\": \"java\", \"starterCode\": \"public class Solution { public int sum(int a, int b) { return 0; } }\" }\n        ],\n        \"testCases\": [\n          { \"input\": \"2 3\", \"expectedOutput\": \"5\", \"weight\": 1, \"visibility\": \"public\" },\n          { \"input\": \"-2 7\", \"expectedOutput\": \"5\", \"weight\": 2, \"visibility\": \"hidden\" }\n        ]\n      }\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Publish assessment",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
        "url": "{{baseUrl}}/api/v1/assessments/{{assessmentId}}/publish"
      }
    },
    {
      "name": "Student run code",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{studentToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/coding-submissions/run",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assessmentId\": \"{{assessmentId}}\",\n  \"questionId\": \"{{questionId}}\",\n  \"language\": \"java\",\n  \"code\": \"public class Solution { public int sum(int a, int b) { return a + b; } }\",\n  \"customInput\": \"2 3\"\n}"
        }
      }
    },
    {
      "name": "Student submit code",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{studentToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/coding-submissions",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assessmentId\": \"{{assessmentId}}\",\n  \"questionId\": \"{{questionId}}\",\n  \"language\": \"java\",\n  \"code\": \"public class Solution { public int sum(int a, int b) { return a + b; } }\"\n}"
        }
      }
    },
    {
      "name": "Student list own coding submissions",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
        "url": "{{baseUrl}}/api/v1/coding-submissions?assessmentId={{assessmentId}}&questionId={{questionId}}"
      }
    },
    {
      "name": "Teacher list coding submissions",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
        "url": "{{baseUrl}}/api/v1/coding-submissions?assessmentId={{assessmentId}}&studentId={{studentId}}&questionId={{questionId}}"
      }
    }
  ]
}
